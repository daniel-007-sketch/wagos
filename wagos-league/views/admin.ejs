<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin - Wagos League</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="icon" href="/logo.svg" />
  <script>
    const nextResetAtISO = '<%= nextResetAtISO %>';
    function updateCountdown() {
      const target = new Date(nextResetAtISO);
      const now = new Date();
      const diffMs = target - now;
      const el = document.getElementById('countdown');
      if (!el) return;
      if (diffMs <= 0) {
        el.textContent = 'Reset soon';
        return;
      }
      const sec = Math.floor(diffMs / 1000) % 60;
      const min = Math.floor(diffMs / (1000*60)) % 60;
      const hr = Math.floor(diffMs / (1000*60*60)) % 24;
      const days = Math.floor(diffMs / (1000*60*60*24));
      el.textContent = `${days}d ${hr}h ${min}m ${sec}s`;
    }
    setInterval(updateCountdown, 1000);
    window.addEventListener('DOMContentLoaded', updateCountdown);
  </script>
</head>
<body class="min-h-screen bg-gray-100 text-gray-800">
  <header class="bg-white shadow">
    <div class="max-w-4xl mx-auto px-4 py-6 flex items-center gap-4">
      <img src="/logo.svg" alt="Wagos League" class="w-10 h-10" />
      <h1 class="text-2xl font-bold">Admin - Wagos League</h1>
      <div id="countdown" class="ml-auto text-sm text-gray-600"></div>
    </div>
  </header>
  <main class="max-w-4xl mx-auto p-4 space-y-6">
    <section class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold mb-2">Stats</h2>
      <p class="text-sm text-gray-600 mb-4">Last reset: <%= stats.lastResetAt || 'N/A' %></p>
      <p>Total players: <strong><%= stats.playersCount %></strong></p>
      <div class="grid md:grid-cols-3 gap-4 mt-4">
        <% (stats.totals || []).forEach(function(t){ %>
          <div class="border rounded p-3">
            <h3 class="font-semibold">Team <%= t.team %></h3>
            <p>Players: <%= t.cnt %></p>
            <p>Total Skill: <%= t.totalSkill || 0 %></p>
          </div>
        <% }) %>
      </div>
    </section>

    <section class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold mb-2">Controls</h2>
      <form method="post" action="/admin/reset">
        <button class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded">Randomize Teams Now</button>
      </form>
      <form method="post" action="/admin/logout" class="mt-3">
        <button class="bg-gray-200 hover:bg-gray-300 text-gray-800 px-4 py-2 rounded">Logout</button>
      </form>
      <% if (message) { %>
        <div class="mt-4 bg-green-50 border border-green-200 text-green-800 rounded p-3"><%= message %></div>
      <% } %>
      <% if (error) { %>
        <div class="mt-4 bg-red-50 border border-red-200 text-red-800 rounded p-3"><%= error %></div>
      <% } %>
    </section>
  </main>
</body>
</html>

